{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS AGI Club GitHub Pages Owner Access Receipt",
  "type": "object",
  "required": [
    "schema",
    "version",
    "name",
    "address",
    "node",
    "mode",
    "issuedAt",
    "expiresAt",
    "lastVerifiedAt",
    "verificationBlock",
    "authority",
    "serverAuthoritative",
    "distributionMode"
  ],
  "properties": {
    "schema": {
      "const": "goalos-agi-club-owner-access/2.0"
    },
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[^.]+\\.club\\.agi\\.eth$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "node": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "mode": {
      "type": "string"
    },
    "registryOwner": {
      "type": "string"
    },
    "wrapperAddress": {
      "type": [
        "string",
        "null"
      ]
    },
    "wrapperLabel": {
      "type": [
        "string",
        "null"
      ]
    },
    "wrappedExpiry": {
      "type": [
        "integer",
        "null"
      ]
    },
    "fuses": {
      "type": [
        "integer",
        "null"
      ]
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastVerifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "verificationBlock": {
      "type": "integer"
    },
    "nonce": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "signatureDigest": {
      "type": "string"
    },
    "authority": {
      "const": "github-pages-static-direct-owner-check"
    },
    "serverAuthoritative": {
      "const": false
    },
    "distributionMode": {
      "const": "public-static-github-pages"
    },
    "canonicalDeployment": {
      "type": "string"
    },
    "canonicalDeploymentMatch": {
      "type": "boolean"
    },
    "protectionBoundary": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
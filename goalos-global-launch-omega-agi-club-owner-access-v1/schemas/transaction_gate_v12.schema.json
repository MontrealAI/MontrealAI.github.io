{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS Transaction Gate v12",
  "type": "object",
  "required": [
    "transaction",
    "receipts",
    "decision"
  ],
  "properties": {
    "transaction": {
      "type": "object"
    },
    "receipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "current",
          "attributable",
          "approved"
        ]
      }
    },
    "decision": {
      "enum": [
        "BLOCKED",
        "ADMITTED_FOR_AUTHORIZED_EXECUTION"
      ]
    }
  }
}
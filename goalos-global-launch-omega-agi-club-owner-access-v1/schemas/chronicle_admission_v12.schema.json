{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS Chronicle Admission v12",
  "type": "object",
  "required": [
    "capability",
    "evidence",
    "rights",
    "scope",
    "version",
    "currentness",
    "knownFailures",
    "reviewerAcceptance",
    "revocation",
    "freshSuccessorTest",
    "decision"
  ],
  "properties": {
    "decision": {
      "enum": [
        "ADMIT",
        "ADMIT_WITH_LIMITS",
        "REPAIR",
        "REJECT",
        "REVOKE",
        "EXPIRE"
      ]
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goalos.example/schemas/global_launch_agi_job_v1.schema.json",
  "title": "GoalOS Global Launch AGI Job",
  "type": "object",
  "required": [
    "schema",
    "id",
    "missionModule",
    "objective",
    "authority",
    "evidence",
    "acceptanceCriteria",
    "status"
  ],
  "properties": {
    "schema": {
      "const": "goalos-global-launch-agi-job/1.0"
    },
    "id": {
      "type": "string"
    },
    "missionModule": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "owner": {
      "type": [
        "string",
        "null"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "items": {}
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {}
    },
    "stopConditions": {
      "type": "array",
      "items": {}
    },
    "status": {
      "enum": [
        "designed",
        "validated",
        "authorized",
        "in_execution",
        "completed",
        "realized",
        "monitored",
        "blocked"
      ]
    },
    "chronicle": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS Launch Mission Contract v12",
  "type": "object",
  "required": [
    "objective",
    "sponsor",
    "decisionAuthority",
    "approvedBudget",
    "timeHorizon",
    "riskAndControl",
    "functions",
    "policyConstraints",
    "evidenceAtStart",
    "acceptanceCriteria",
    "evaluator",
    "exclusions",
    "stopEscalationRollback"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "sponsor": {
      "type": "string",
      "minLength": 1
    },
    "decisionAuthority": {
      "type": "string",
      "minLength": 1
    },
    "approvedBudget": {
      "type": "number",
      "minimum": 0
    },
    "capitalAvailability": {
      "type": "number",
      "minimum": 0
    },
    "timeHorizon": {
      "type": "number",
      "minimum": 0
    },
    "deadline": {
      "type": "string"
    },
    "riskAndControl": {
      "type": "object"
    },
    "functions": {
      "type": "array",
      "minItems": 1
    },
    "policyConstraints": {
      "type": "object"
    },
    "evidenceAtStart": {
      "type": "object"
    },
    "acceptanceCriteria": {
      "type": "string"
    },
    "evaluator": {
      "type": "string"
    },
    "exclusions": {
      "type": "string"
    },
    "publicationAndConfidentiality": {
      "type": "string"
    },
    "stopEscalationRollback": {
      "type": "string"
    },
    "chronicleEligibility": {
      "type": "string"
    },
    "frozenAt": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}